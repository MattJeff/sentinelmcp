.LSOverride
Icon?

# Rust
target/
**/target/
Cargo.lock
# Lockfile du workspace tracke (binaire => builds reproductibles, requis par
# `brew install --HEAD` qui passe --locked via std_cargo_args)
!/sentinel/Cargo.lock

# Node / Vite / Tauri
node_modules/
dist/
# dist/ a la racine du depot contient le packaging (formule Homebrew), pas un
# build Vite : on re-inclut uniquement dist/homebrew/
!/dist/
/dist/*
!/dist/homebrew/
dist-ssr/
.vite/
*.local

# Tauri build artifacts (we ship the .dmg via Releases, not in git)
sentinel/sentinel-desktop/src-tauri/target/
sentinel/sentinel-desktop/src-tauri/gen/

# Editors
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Env
.env
.env.local
.env.*.local

# Apple signing / notarization artifacts — never commit these
*.p12
*.provisionprofile
*.cer
*.mobileprovision
*.certSigningRequest

# OS
Thumbs.db
ehthumbs.db

# Tests output
/tmp/sentinel-emails/
/tmp/sentinel-mcp/
