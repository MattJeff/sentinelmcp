{
  "$id": "sentinel://stix/2.1/software.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "STIX 2.1 software SCO (subset)",
  "type": "object",
  "properties": {
    "type": { "type": "string", "const": "software" },
    "spec_version": { "type": "string", "const": "2.1" },
    "id": {
      "type": "string",
      "pattern": "^software--[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "name": { "type": "string", "minLength": 1 },
    "cpe": { "type": "string" },
    "swid": { "type": "string" },
    "languages": { "type": "array", "items": { "type": "string" } },
    "vendor": { "type": "string" },
    "version": { "type": "string" }
  },
  "required": ["type", "spec_version", "id", "name"],
  "additionalProperties": true
}
