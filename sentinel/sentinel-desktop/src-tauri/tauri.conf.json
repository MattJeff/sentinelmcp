{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel MCP",
  "version": "0.2.1",
  "identifier": "com.sentinel-mcp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Sentinel MCP",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "Discover and monitor MCP servers your AI agents contact",
    "longDescription": "Sentinel MCP scans the MCP servers your AI agents contact, fingerprints them with canonical SHA-256, watches for rug-pulls and tool poisoning, and produces a signed OWASP MCP09/MCP03 compliance report.",
    "copyright": "© 2026 Sentinel MCP",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "hardenedRuntime": true,
      "providerShortName": "YV2MS7RRD5",
      "entitlements": "entitlements.plist"
    }
  }
}
